version: "3.9"

volumes:
  ollama-data:
  redis_data:


networks:
  app-network-develop:
    driver: bridge
    ipam:
      config:
        - subnet: 172.33.0.0/24

services:
  backend:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: osce-backend-only-dev
    environment:
      - PYTHONPATH=/app/osce-backend
      - DJANGO_DEBUG=False
      - BASE_DIR=/app/osce-backend
      - MEDIA_DIR=/app/osce-backend/media
      - EXTERNAL_IP=${HOST_IP}
      - TURN_PORT=3433
      - TURN_USERNAME=osce
      - TURN_CREDENTIAL=osce
      - OLLAMA_BASE_URL=http://${HOST_IP}:11333
    volumes:
      - ./.osce:/app/osce-backend/.osce 
      - ./backend_api:/app/osce-backend/backend_api
      - ./mgmt:/app/osce-backend/mgmt
      - ./middleware:/app/osce-backend/middleware
      - ./osce:/app/osce-backend/osce
      - ./talker:/app/osce-backend/talker
      - ./exceptions.py:/app/osce-backend/exceptions.py
      - ./manage.py:/app/osce-backend/manage.py
      - ./db:/app/osce-backend/db
      - ./log:/app/osce-backend/log
      - ./media:/app/osce-backend/media
      - ./backend_api/models:/app/osce-backend/backend_api/models
      - ./backend_api/linly_talker/checkpoints:/app/osce-backend/backend_api/linly_talker/checkpoints
    working_dir: /app/osce-backend
    command: >
      bash -c "
        python3.13 manage.py collectstatic --noinput --settings=backend_api.settings 
        python3.13 manage.py makemigrations &&  python3.13 manage.py migrate --noinput
        uvicorn backend_api.asgi:application --host 0.0.0.0 --port 8088 --workers 1 --timeout-keep-alive 600 --timeout-graceful-shutdown 600
        "
    ports:
      - "8088:8088"
    networks:
      app-network-develop:
        ipv4_address: 172.33.0.3 # 鎖定後端 IP
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [ gpu ]
    depends_on:
      ollama:
        condition: service_started

  coturn:
    image: coturn/coturn:4.6.2
    container_name: osce-coturn-only-dev
    restart: unless-stopped
    ports:
      - "12006:12006"
      - "12006:12006/udp"
    networks:
      app-network-develop:
        ipv4_address: 172.33.0.6 # 鎖定 CoTURN IP
    command: >
      turnserver
      --log-file=stdout
      --realm=osce.local
      --user=osce:osce
      --lt-cred-mech
      --fingerprint
      --no-cli
      --listening-port=12006
      --tls-listening-port=12006
      --listening-ip=0.0.0.0
      --no-udp-relay=false 
      --min-port=10000
      --max-port=10050
      --no-tcp-relay=false
      --no-tcp=false
      --external-ip=118.163.52.174
      --relay-ip=172.33.0.6
      --allowed-peer-ip=0.0.0.0-255.255.255.255
      --allow-loopback-peers

  ollama:
    image: ollama/ollama:0.15.5-rc3
    container_name: osce-ollama-only-dev
    environment:
      - OLLAMA_HOST=0.0.0.0
    ports:
      - "11333:11434"
    volumes:
      - ./ollama:/root/.ollama
    restart: unless-stopped
    networks:
      app-network-develop:
        ipv4_address: 172.33.0.5
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [ gpu ]
    entrypoint: [ "/usr/bin/ollama", "serve" ]

  nginx:
    image: nginx:1.27.3-alpine
    container_name: osce-nginx-only-dev
    ports:
      - "12222:80"
      - "12005:443"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./mount/dist:/usr/share/nginx/html
      - ./mount/static:/app/osce-backend/static
      - ./fullchain.pem:/etc/ssl/certs/fullchain.pem:ro
      - ./privkey.pem:/etc/ssl/private/privkey.pem:ro
    depends_on:
      - backend
    networks:
      app-network-develop:
        ipv4_address: 172.33.0.4