version: "3.9"

volumes:
  ollama-data:
  redis_data:

networks:
  app-network-develop:
    driver: bridge

services:
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: osce-backend-dev
    environment:
      - PYTHONPATH=/app/osce-backend
      - DJANGO_DEBUG=False
      - BASE_DIR=/app/osce-backend
      - MEDIA_DIR=/app/osce-backend/media
    volumes:
      - ./osce-backend:/app/osce-backend
      - ./db:/app/osce-backend/db
      - ./log:/app/osce-backend/log
      - ./osce-backend/media:/app/osce-backend/media
    working_dir: /app/osce-backend
    command: >
      bash -c "
        python3.13 manage.py collectstatic --noinput --settings=backend_api.settings 
        python3.13 manage.py makemigrations &&  python3.13 manage.py migrate --noinput
        uvicorn backend_api.asgi:application --host 0.0.0.0 --port 8004 --workers 1 --timeout-keep-alive 300
        "
    ports:
      - "8004:8000"
    networks:
      - app-network-develop

  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
    volumes:
      - ./osce-frontend:/app/osce-frontend
      - ./dist:/app/osce-frontend/dist
    command: >
      bash -c " 
            npm run build:admin && 
            npm run build:user"
    networks:
      - app-network-develop

  ollama:
    image: ollama/ollama:0.5.7
    container_name: osce-ollama-dev
    ports:
      - "11404:11434"
    volumes:
      - ./ollama:/root/.ollama
    restart: unless-stopped
    networks:
      - app-network-develop
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:11404/api/tags" ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  nginx:
    image: nginx:1.27.3-alpine
    container_name: osce-nginx-dev
    ports:
      - "12001:80"
      - "12004:443"
    volumes:
      - ./development/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./dist:/usr/share/nginx/html
      - ./static:/app/osce-backend/static
      - ./fullchain.pem:/etc/ssl/certs/fullchain.pem:ro
      - ./privkey.pem:/etc/ssl/private/privkey.pem:ro
    depends_on:
      - backend
      - frontend
    networks:
      - app-network-develop

  coturn:
    image: coturn/coturn:4.6.2
    container_name: osce-coturn-dev
    network_mode: "host"
    command: 
      - "-n"
      - "--log-file=stdout"
      - "--listening-port=3474"      
      - "--min-port=49152"
      - "--max-port=49160"
      - "--realm=osce.local"
      - "--user=admin:osce"
      - "--lt-cred-mech"
      - "--fingerprint"
      - "--external-ip=192.168.1.4"  
    restart: unless-stopped