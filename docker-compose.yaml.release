version: "3.9"

volumes:
  ollama-data:
  redis_data:

networks:
  # 鎖定網段，確保 IP 不會隨機變動
  app-network-release:
    driver: bridge
    ipam:
      config:
        - subnet: 172.18.0.0/24

services:
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: osce-backend-release
    environment:
      - PYTHONPATH=/app/osce-backend
      - DJANGO_DEBUG=False
      - BASE_DIR=/app/osce-backend
      - MEDIA_DIR=/app/osce-backend/media
      - OLLAMA_BASE_URL=http://${HOST_INNER_IP}:11400/v1
      - TURN_STUN_SERVER=turn:118.163.52.174:12004?transport=tcp
      # - TURN_STUN_SERVER=turn:192.168.41.20:3478
      # - TURN_STUN_SERVER=stun:stun.l.google.com:19302
      - TURN_USERNAME=osce
      - TURN_CREDENTIAL=osce
    volumes:
      - ./osce-backend:/app/osce-backend
      - ./mount/db:/app/osce-backend/db
      - ./mount/log:/app/osce-backend/log
    working_dir: /app/osce-backend
    command: >
      bash -c "
        python3.13 manage.py collectstatic --noinput --settings=backend_api.settings 
        python3.13 manage.py makemigrations &&  python3.13 manage.py migrate --noinput
        uvicorn backend_api.asgi:application --host 0.0.0.0 --port 8010 --workers 1 --timeout-keep-alive 300
        "
    ports:
      - "8010:8010"
    networks:
      app-network-release:
        ipv4_address: 172.18.0.3 # 鎖定後端 IP
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    depends_on:
      ollama:
        condition: service_started

  coturn:
    image: coturn/coturn:4.6.2
    container_name: osce-coturn-release
    restart: unless-stopped
    ports:
      - "3478:3478"
      - "3478:3478/udp"
      - "10000-10050:10000-10050/udp"
    networks:
      app-network-release:
        ipv4_address: 172.18.0.2 # 鎖定 CoTURN IP
    command:
      - turnserver
      - -n
      - --log-file=stdout
      - --lt-cred-mech
      - --fingerprint
      - --realm=osce.local
      - --user=osce:osce
      - --listening-port=3478
      - --min-port=10000
      - --max-port=10050
      - --verbose
      - --external-ip=${HOST_INNER_IP}/172.18.0.2
      - --relay-ip=172.18.0.2
      - --listening-ip=0.0.0.0
      - --allowed-peer-ip=0.0.0.0-255.255.255.255
      - --allow-loopback-peers
      - --no-cli

  coturn-12004:
    image: coturn/coturn:4.6.2
    container_name: osce-coturn-12004-release
    restart: unless-stopped
    ports:
      - "12004:12004"
      - "12004:12004/udp"
    networks:
      app-network-release:
        ipv4_address: 172.18.0.7
    command: >
      turnserver
      --log-file=stdout
      --realm=osce.local
      --user=osce:osce
      --lt-cred-mech
      --fingerprint
      --no-cli
      --listening-port=12004
      --tls-listening-port=12004
      --listening-ip=0.0.0.0
      --no-udp-relay=false 
      --min-port=10000
      --max-port=10050
      --no-tcp-relay=false
      --no-tcp=false
      --external-ip=118.163.52.174
      --relay-ip=172.18.0.7
      --allowed-peer-ip=0.0.0.0-255.255.255.255
      --allow-loopback-peers
      
  nginx:
    image: nginx:1.27.3-alpine
    container_name: osce-nginx-release
    ports:
      - "12345:80"
      - "12007:443"
    volumes:
      - ./nginx.conf.release:/etc/nginx/conf.d/default.conf:ro
      - ./mount/dist:/usr/share/nginx/html
      - ./mount/static:/app/osce-backend/static
      - ./fullchain.pem:/etc/ssl/certs/fullchain.pem:ro
      - ./privkey.pem:/etc/ssl/private/privkey.pem:ro
    depends_on:
      - backend
      - frontend
    networks:
      app-network-release:
        ipv4_address: 172.18.0.4

  ollama:
    image: ollama/ollama:0.15.5-rc3
    container_name: osce-ollama-release
    environment:
      - OLLAMA_HOST=0.0.0.0
    ports:
      - "11400:11434"
    volumes:
      - ./ollama:/root/.ollama
    restart: unless-stopped
    networks:
      app-network-release:
        ipv4_address: 172.18.0.5
    entrypoint: ["/usr/bin/ollama", "serve"]

  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
    container_name: osce-frontend-release
    volumes:
      - ./osce-frontend:/app/osce-frontend
      - /app/osce-frontend/node_modules
      - ./mount/dist:/app/osce-frontend/dist
    command: >
      bash -c " 
            npm run build:admin && 
            npm run build:user"
    networks:
      app-network-release:
        ipv4_address: 172.18.0.6