version: "3.9"

volumes:
  ollama-data:
  redis_data:

networks:
  # 鎖定網段，確保 IP 不會隨機變動
  app-network-release:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.2.0/24

services:
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: osce-backend-dev
    environment:
      - PYTHONPATH=/app/osce-backend
      - DJANGO_DEBUG=False
      - BASE_DIR=/app/osce-backend
      - MEDIA_DIR=/app/osce-backend/media
      - EXTERNAL_IP=${HOST_IP}
      - OLLAMA_BASE_URL=http://${HOST_IP}:11400/v1
    volumes:
      - ./osce-backend:/app/osce-backend
      - ./mount/db:/app/osce-backend/db
      - ./mount/log:/app/osce-backend/log
      - ./mount/media:/app/osce-backend/media
      - ./mount/models:/app/osce-backend/backend_api/models
    working_dir: /app/osce-backend
    command: >
      bash -c "
        python3.13 manage.py collectstatic --noinput --settings=backend_api.settings 
        python3.13 manage.py makemigrations &&  python3.13 manage.py migrate --noinput
        uvicorn backend_api.asgi:application --host 0.0.0.0 --port 8010 --workers 1 --timeout-keep-alive 300
        "
    ports:
      - "8010:8010"
    networks:
      app-network-release:
        ipv4_address: 172.20.2.3 # 鎖定後端 IP
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    depends_on:
      ollama:
        condition: service_started

  coturn:
    image: coturn/coturn:4.6.2
    container_name: osce-coturn-dev
    restart: unless-stopped
    ports:
      - "3478:3478"
      - "3478:3478/udp"
      - "10000-10050:10000-10050/udp"
    networks:
      app-network-release:
        ipv4_address: 172.20.2.2 # 鎖定 CoTURN IP
    command:
      - turnserver
      - -n
      - --log-file=stdout
      - --lt-cred-mech
      - --fingerprint
      - --realm=osce.local
      - --user=osce:osce
      - --listening-port=3478
      - --min-port=10000
      - --max-port=10050
      - --verbose
      - --external-ip=${HOST_IP}/172.20.2.2
      - --relay-ip=172.20.2.2
      - --listening-ip=0.0.0.0
      - --allowed-peer-ip=0.0.0.0-255.255.255.255
      - --allow-loopback-peers
      - --no-cli

  nginx:
    image: nginx:1.27.3-alpine
    container_name: osce-nginx-dev
    ports:
      - "12001:80"
      - "12004:443"
    volumes:
      - ./nginx.conf.develop:/etc/nginx/conf.d/default.conf:ro
      - ./mount/dist:/usr/share/nginx/html
      - ./mount/static:/app/osce-backend/static
      - ./fullchain.pem:/etc/ssl/certs/fullchain.pem:ro
      - ./privkey.pem:/etc/ssl/private/privkey.pem:ro
    depends_on:
      - backend
      - frontend
    networks:
      app-network-release:
        ipv4_address: 172.20.2.4

  ollama:
    image: ollama/ollama:0.15.5-rc3
    container_name: osce-ollama-dev
    environment:
      - OLLAMA_HOST=0.0.0.0
    ports:
      - "11400:11434"
    volumes:
      - ./ollama:/root/.ollama
    restart: unless-stopped
    networks:
      app-network-release:
        ipv4_address: 172.20.2.5
    entrypoint: ["/usr/bin/ollama", "serve"]

  frontend:
    build:
      context: .
      dockerfile: Dockerfile.frontend
    volumes:
      - ./osce-frontend:/app/osce-frontend
      - /app/osce-frontend/node_modules
      - ./mount/dist:/app/osce-frontend/dist
    command: >
      bash -c " 
            npm run build:admin && 
            npm run build:user"
    networks:
      app-network- release:
        ipv4_address: 172.20.2.6